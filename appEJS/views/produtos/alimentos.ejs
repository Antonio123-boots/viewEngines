<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <div class="container">
      <header class="cabecalho">
        <h2 class="voltar"><a href="/produtos">voltar</a></h2>
        <h1 class="titulo"><%= title %></h1>
      </header>

      <main>
        <h2>Bem vindo para a área de <%= title %></h2>
        <p>Aqui você poderá comprar tudo que deseja</p>
        <div class="produtos-card">
          <%alimentos.forEach(alimentos => { %>
          <div class="alimento-nome"> <% alimento.nome %> </div>
          <div class="alimento-descrição"> descrição do <% alimento.nome %> </div>
          <div class="produto-preço"> R$ <% alimento.preco.toFixed(2).replace('.',',') %> </div>
          <button class="botao">Comprar</button>
        </div>
        <% })%>
      </main>

      <footer class="site-footer">
        <p>Número para contato: (48) 94002-8922</p>
      </footer>
    </div>
  </body>
</html>