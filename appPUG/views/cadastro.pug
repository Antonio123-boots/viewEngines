extends layout

block content
  header.cabecalho
    h1.titulo #{title}
    p.sutitulo Bem vindo ao site de #{title}

    nav.menu
      ul
        li
          a(href="/" onclick="navega()") Home
        li
          a(href="/apan/mensagem" onclick="navega()") Mensagem
        li
          a(href="/apan/cadastro" onclick="navega()") cadastro 
  
  main
    img(src="https://upload.wikimedia.org/wikipedia/pt/thumb/6/6a/VoleiBlumenau.png/250px-VoleiBlumenau.png", alt="equipe de voleibol Blumenau")

    form(action="/apan/cadastro" method="post" class="formulario" id="formCadastro")
      label(for="nome") Nome:
      input(type="text" id="nome" name="nome" required)
      br
      label(for="email") Email:
      input(type="email" id="email" name="email" required)
      br
      label(for="senha") Senha:
      input(type="password" id="senha" name="senha" required)
      br
      button.btn(type="submit" onclick="cadastrarUsuario()") Cadastrar
