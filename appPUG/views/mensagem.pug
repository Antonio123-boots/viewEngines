extends layout

block content
  header.cabecalho
    h1.titulo #{title}
    p.sutitulo Bem vindo ao site #{title}

    nav.menu
      ul
        li
          a(href="/" onclick="navega()") Home
        li
          a(href="/apan/mensagem" onclick="navega()") Mensagem
        li
          a(href="/apan/cadastro" onclick="navega()") cadastro 
  
  main
    form(action="/apan/mensagem" method="post" class="formulario" id="formMensagem")
      label(for="nome") Nome:
      input(type="text" id="nome" name="nome" required)
      br
      label(for="mensagem") Mensagem:
      textarea(id="mensagem" name="mensagem" required)
      br
      button.btn(type="submit" onclick="enviarMensagem()") Enviar Mensagem

    script(src="/javascript/mensagem.js")